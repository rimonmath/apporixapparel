{
  "name": "apporixapparel",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "type-check": "vue-tsc --build",
    "format": "prettier --write src/",
    "dev:vue": "vite --port 5124",
    "dev:hono": "tsx watch hono/index.ts",
    "dev:tsc": "tsc --project tsconfig.node.json --watch",
    "prod:tsc": "tsc --project tsconfig.node.json",
    "prod:tsc-force": "tsc --project tsconfig.node.json --noEmitOnError false",
    "dev-old": "concurrently \"npm run dev:vue\" \"npm run dev:tsc\" \"npm run dev:hono\"",
    "dev": "concurrently \"npm run dev:vue\" \"tsx watch hono/index.ts\"",
    "preview": "vite preview",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "build-only": "vite build",
    "minify:hono": "mkdir -p hdist/hono.min && find hdist/hono -type f -name '*.js' -print0 | xargs -0 esbuild --outdir=hdist/hono.min --outbase=hdist/hono --minify --format=esm --platform=node",
    "bundle:hono": "esbuild hdist/hono/index.js --bundle --minify --format=esm --platform=node --outfile=hono.min.js --external:fs --external:path --external:os --external:crypto --external:assert --external:dotenv --external:pg --external:postgres --external:drizzle-orm --external:drizzle-orm/* --external:hono --external:hono/* --external:argon2",
    "build": "run-p type-check \"build-only {@}\" -- && npm run prod:tsc && npm run bundle:hono",
    "build:hono": "npm run prod:tsc",
    "prod": "node hono.min.js",
    "deploy": "curl -X POST https://apporixapparel.com/api/public/cicd -H \"Content-Type: application/json\" -d '{\"password\":\"rimonrimonrimon\"}'"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@hono/standard-validator": "^0.1.2",
    "@tailwindcss/vite": "^4.1.13",
    "@vueup/vue-quill": "^1.2.0",
    "argon2": "^0.43.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.7.4",
    "naive-ui": "^2.43.1",
    "ofetch": "^1.4.1",
    "pg": "^8.16.2",
    "pinia": "^3.0.3",
    "postgres": "^3.4.7",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.13",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@hono/vite-build": "^1.3.0",
    "@hono/vite-dev-server": "^0.19.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.16.5",
    "@types/pg": "^8.15.4",
    "@vicons/ionicons5": "^0.13.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.2",
    "esbuild": "^0.25.10",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.10",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "terser": "^5.44.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.0.6",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vue-tsc": "^3.0.4"
  }
}
